APP_ENV=development
APP_PORT=8000
APP_NAME=lummevia-orchestrator-api
APP_VERSION=0.1.0

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lummevia
POSTGRES_USER=lummevia
POSTGRES_PASSWORD=lummevia

REDIS_HOST=redis
REDIS_PORT=6379

# Local Phoenix via docker compose (development only)
PHOENIX_ENABLED=true
PHOENIX_HOST=phoenix
PHOENIX_PORT=6006
PHOENIX_BASE_URL=http://phoenix:6006

# External Phoenix via Coolify (shared environment example)
# PHOENIX_HOST=phoenix.coolify.internal
# PHOENIX_PORT=6006
# PHOENIX_BASE_URL=https://phoenix.example.com

YOUTRACK_BASE_URL=
YOUTRACK_TOKEN=

GITHUB_TOKEN=
GITHUB_ORG=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ENABLED=false
DEEPSEEK_TIMEOUT_SECONDS=60
# Validated for the controlled PM dry-run today.
MODEL_PM_PROVIDER=DEEPSEEK
MODEL_PM_NAME=deepseek-chat
# The V4 names below remain placeholders until DeepSeek naming is confirmed.
MODEL_PO_PROVIDER=DEEPSEEK
MODEL_PO_NAME=deepseek-v4-strong-placeholder
MODEL_DEV_PROVIDER=DEEPSEEK
MODEL_DEV_NAME=deepseek-v4-lite-placeholder
MODEL_QA_PROVIDER=DEEPSEEK
MODEL_QA_NAME=deepseek-v4-lite-placeholder
MODEL_QC_PROVIDER=DEEPSEEK
MODEL_QC_NAME=deepseek-v4-qc-placeholder

RUNTIME_PERSISTENCE_ENABLED=false
RUNTIME_DATABASE_URL=

# Future Kilo CLI configuration (real CLI execution is still disabled)
KILO_ENABLED=false
KILO_CLI_PATH=
KILO_WORKSPACE_ROOT=
KILO_DEFAULT_TIMEOUT_SECONDS=300
KILO_DRY_RUN=true
KILO_ALLOWED_REPOS=
KILO_MAX_OUTPUT_BYTES=32768
